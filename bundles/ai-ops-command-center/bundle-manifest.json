  "scripts": [
    {
      "file": "setup-ai-apis.sh",
      "lines": 698,
      "role": "flagship",
      "category": "setup",
      "description": "Full API key setup wizard with validation, connectivity testing, .env generation, and test suite for 6+ AI providers",
      "features": [
        "OpenAI API key validation",
        "Anthropic API key validation",
        "Groq API key validation",
        "xAI/Grok API key validation",
        "Google/Gemini API key validation",
        "Cohere API key validation",
        "Connectivity testing against live endpoints",
        "Auto-detection of existing configurations",
        ".env template generation",
        "Full test suite with pass/fail reporting"
      ],
      "usage": "./setup-ai-apis.sh",
      "modes": ["interactive", "non-interactive", "validate-only"]
    },
    {
      "file": "ai-cli-diagnostics.sh",
      "lines": 121,
      "role": "diagnostics",
      "category": "monitoring",
      "description": "Comprehensive environment audit: shell layout, Python inventory, virtual envs, Aider config, LiteLLM status, API reachability — all auto-redacted",
      "features": [
        "Shell and PATH analysis",
        "System information (macOS version)",
        "Python executable detection and version",
        "Virtual environment detection",
        "Full pip freeze package inventory",
        "Aider configuration audit",
        "LiteLLM proxy status check",
        "Grok CLI installation state",
        "API endpoint reachability testing",
        "Auto-redaction of all sensitive data"
      ],
      "usage": "./ai-cli-diagnostics.sh",
      "output": "Terminal + timestamped log file in $HOME"
    },
    {
      "file": "ai-resource-manager.sh",
      "lines": 140,
      "role": "resource-governance",
      "category": "monitoring",
      "description": "CPU and memory governance per AI tool with configurable limits, pre-flight checks, and auto-cleanup",
      "features": [
        "Memory limits per tool (default: 4096 MB)",
        "CPU caps per tool (default: 80%, auto-kill at 95%)",
        "Concurrent tool limits (default: 3)",
        "Pre-flight resource availability checks",
        "Process lifecycle management with timeouts",
        "Active tool tracking via /tmp/active_ai_tools",
        "Automatic cleanup of stale entries"
      ],
      "usage": [
        "./ai-resource-manager.sh launch 'command' 'name' [memory_mb]",
        "./ai-resource-manager.sh status",
        "./ai-resource-manager.sh cleanup"
      ],
      "configurable": {
        "MAX_MEMORY_PER_TOOL": "4096 MB",
        "MAX_CPU_PER_TOOL": "80%",
        "MAX_CONCURRENT_TOOLS": 3
      }
    },
    {
      "file": "ai-watchdog.sh",
      "lines": 123,
      "role": "process-protection",
      "category": "monitoring",
      "description": "Continuous monitoring daemon that detects and terminates runaway AI processes based on CPU and runtime thresholds",
      "features": [
        "High-CPU process detection (threshold: 90%)",
        "Runtime limit enforcement (default: 2 hours)",
        "Top 5 resource consumer identification",
        "Graceful termination (SIGTERM) with fallback to force kill (SIGKILL)",
        "Timestamped logging to /tmp/ai-watchdog.log",
        "System-wide CPU and memory monitoring",
        "Three operation modes: run, once, status"
      ],
      "usage": [
        "./ai-watchdog.sh run   # continuous monitoring",
        "./ai-watchdog.sh once  # single check cycle",
        "./ai-watchdog.sh status # show current status"
      ],
      "configurable": {
        "MAX_CPU_THRESHOLD": "90%",
        "MAX_RUNTIME_HOURS": 2,
        "CHECK_INTERVAL": "60 seconds"
      }
    },
    {
      "file": "ai_unified_menu.sh",
      "lines": 413,
      "role": "unified-interface",
      "category": "interface",
      "description": "Interactive color-coded TUI menu providing unified access to all AI tools, quick actions, and environment checks",
      "features": [
        "Color-coded terminal UI (bold, dim, green, red, cyan, yellow, blue, purple)",
        "Grok CLI submenu (interactive, quick prompt, file analysis, code review, git analysis)",
        "Ollama submenu (generate, list models, pull models, interactive chat)",
