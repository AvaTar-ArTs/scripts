  "providers": [
    {
      "name": "OpenAI",
      "type": "cloud-api",
      "env_var": "OPENAI_API_KEY",
      "key_prefix": "sk-",
      "endpoint": "https://api.openai.com/v1/models",
      "setup_script": "setup-ai-apis.sh"
    },
    {
      "name": "Anthropic",
      "type": "cloud-api",
      "env_var": "ANTHROPIC_API_KEY",
      "key_prefix": "sk-ant-",
      "endpoint": "https://api.anthropic.com/v1/messages",
      "setup_script": "setup-ai-apis.sh"
    },
    {
      "name": "Groq",
      "type": "cloud-api",
      "env_var": "GROQ_API_KEY",
      "key_prefix": "gsk-",
      "endpoint": "https://api.groq.com/openai/v1/models",
      "setup_script": "setup-ai-apis.sh"
    },
    {
      "name": "xAI / Grok",
      "type": "cloud-api",
      "env_var": "GROK_API_KEY",
      "key_prefix": "xai-",
      "endpoint": "https://api.x.ai/v1/models",
      "setup_script": "grok_integration.sh"
    },
    {
      "name": "Google / Gemini",
      "type": "cloud-api",
      "env_var": "GOOGLE_API_KEY",
      "key_prefix": "AIza-",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models",
      "setup_script": "setup-ai-apis.sh"
    },
    {
      "name": "Cohere",
      "type": "cloud-api",
      "env_var": "COHERE_API_KEY",
      "key_prefix": "varies",
      "endpoint": "https://api.cohere.ai/v1/models",
      "setup_script": "setup-ai-apis.sh"
    },
    {
      "name": "Ollama",
      "type": "local",
      "env_var": "OLLAMA_HOST",
      "key_prefix": "n/a",
      "endpoint": "http://localhost:11434/api/tags",
      "setup_script": "ollama_install.sh"
    },
    {
      "name": "MCP Servers",
      "type": "local/remote",
      "env_var": "varies",
      "key_prefix": "n/a",
      "endpoint": "varies by server",
      "setup_script": "mcp-lifecycle-manager.sh"
    }
